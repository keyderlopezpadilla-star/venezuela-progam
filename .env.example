# ====================================================
# VENEZUELA SOLIDARIA — Environment Configuration
# ====================================================
# Copy this file to .env.local and fill in the values.

# === Application ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Venezuela Solidaria"
NODE_ENV=development

# === Database (PostgreSQL / Neon / Supabase / Railway) ===
DATABASE_URL="postgresql://user:password@localhost:5432/venezuela_solidaria?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/venezuela_solidaria?schema=public"

# === NextAuth (Auth.js v5) ===
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OAuth providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# === Stripe (Payments) ===
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_CURRENCY="USD"

# === Resend (Transactional Email) ===
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@venezuelasolidaria.org"
RESEND_REPLY_TO="contacto@venezuelasolidaria.org"

# === Cloudinary (Media storage) ===
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="venezuela-solidaria"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# === Mapbox (Maps) ===
NEXT_PUBLIC_MAPBOX_TOKEN=""

# === Analytics ===
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# === Security ===
ENCRYPTION_KEY="32-byte-base64-key-for-sensitive-data-encryption"
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# === Cron / Background jobs ===
CRON_SECRET=""

# === Feature flags ===
FEATURE_DONATIONS_ENABLED="true"
FEATURE_VOLUNTEERS_ENABLED="true"
FEATURE_HELP_REQUESTS_ENABLED="true"
FEATURE_DARK_MODE_ENABLED="true"
